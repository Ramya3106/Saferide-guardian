# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=""

# Encryption key for sensitive fields in MongoDB (64 hex chars)
# Generate once and keep stable: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-hex-character-key

# Email Configuration (Gmail)
# Reset and verification emails are sent from divyadharshana3@gmail.com
RESET_EMAIL_USER=divyadharshana3@gmail.com
RESET_EMAIL_PASS=your-gmail-app-password
RESET_EMAIL_FROM=SafeRide Guardian <divyadharshana3@gmail.com>

# Backward-compatible aliases used if RESET_EMAIL_* is not set
EMAIL_USER=divyadharshana3@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=SafeRide Guardian <divyadharshana3@gmail.com>

# Development Settings
# Set to true to return verification codes in API responses (development only)
RETURN_VERIFY_CODE=false
